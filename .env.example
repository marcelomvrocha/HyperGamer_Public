# Local default database file. For production, prefer an absolute path on a
# persistent disk, for example: file:/var/lib/hypergamer/hypergamer.db
DATABASE_URL="file:./muscle_app.db"

# Standalone public repo default: run at the root (recommended).
# Set to /hypergamer only if you are mounting the app under that path.
NEXT_PUBLIC_BASE_PATH=""

# Optional runtime overrides for standalone hosting.
HOSTNAME=0.0.0.0
PORT=3001

# Welcome email on new profile (registration). If SMTP_HOST or EMAIL_FROM is missing,
# the welcome message is only logged to the server console.
# SMTP_USER / SMTP_PASS omit if your relay allows unauthenticated send (rare).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="HyperGamer <noreply@example.com>"
# Optional: shown in welcome email as "Open HyperGamer" (https URL).
APP_PUBLIC_URL=http://127.0.0.1:3001
# Optional: replies from the user go here instead of EMAIL_FROM.
EMAIL_REPLY_TO=

# Optional: if set together with SMTP settings, in-app issue reports are emailed here.
REPORT_EMAIL_TO=
REPORT_EMAIL_SUBJECT_PREFIX="[HyperGamer]"
